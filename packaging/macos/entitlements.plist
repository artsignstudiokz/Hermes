<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Network: outbound to brokers + ngrok + Telegram + baicore.kz; inbound from PyWebView -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- PyInstaller bootstraps Python via fork+exec; allow JIT for embedded Python -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- File access for the user's data dir (~/Library/Application Support/Hermes) -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
