---
/**
 * Adaptive Engine showcase — visualizes the regime detector & auto-calibration.
 * Three states (trend / flat / high_vol) cycle through with live transitions
 * — same logic as the actual Hermes runtime, but presented as a hero feature.
 */
---

<section id="adaptive" class="relative py-28 md:py-36 overflow-hidden">
  <div class="meander-stripe absolute inset-x-0 top-0 h-5 opacity-30"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="reveal max-w-3xl mx-auto text-center">
      <p class="uppercase tracking-[0.32em] text-xs text-gold-deep">Адаптивный движок</p>
      <h2 class="display mt-3 text-4xl md:text-6xl font-semibold tracking-tight">
        Hermes <span class="gold-text-anim">читает рынок</span> <br/> и подстраивается сам.
      </h2>
      <p class="mt-5 font-serif text-lg text-ink/70 max-w-2xl mx-auto">
        Каждое воскресенье в 03:00 запускается walk-forward валидация на 90 днях рынка.
        Champion-challenger логика: новые параметры применяются только если они лучше
        старых на ≥5% по Sharpe.
      </p>
    </div>

    <div class="mt-16 grid gap-8 lg:grid-cols-[1.1fr_0.9fr] items-center">
      <!-- Left: live regime visualization -->
      <div class="reveal-late">
        <div class="regime-stage marble-card p-8 relative overflow-hidden">
          <div class="flex items-center justify-between mb-6">
            <div>
              <p class="text-[10px] uppercase tracking-[0.32em] text-ink/50">Текущий рыночный режим</p>
              <p class="display text-2xl font-semibold mt-1">EURUSD · 4h</p>
            </div>
            <div class="ping-double relative flex h-2 w-2">
              <span class="absolute inset-0 rounded-full bg-laurel opacity-70 animate-ping"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-laurel"></span>
            </div>
          </div>

          <!-- Live regime indicator -->
          <div class="regime-display">
            <div class="regime-card regime-trend">
              <div class="regime-icon">📈</div>
              <div>
                <p class="regime-label">Тренд</p>
                <p class="regime-meta">ADX 32 · EMA50/200 ✓</p>
              </div>
              <div class="regime-confidence">
                <span class="regime-conf-bar" style="--w: 78%"></span>
                <span class="regime-conf-val">78%</span>
              </div>
            </div>
            <div class="regime-card regime-flat">
              <div class="regime-icon">⚖</div>
              <div>
                <p class="regime-label">Флэт</p>
                <p class="regime-meta">ADX 17 · ATR low</p>
              </div>
              <div class="regime-confidence">
                <span class="regime-conf-bar" style="--w: 22%"></span>
                <span class="regime-conf-val">22%</span>
              </div>
            </div>
            <div class="regime-card regime-vol">
              <div class="regime-icon">⚡</div>
              <div>
                <p class="regime-label">Высокая волатильность</p>
                <p class="regime-meta">ATR rank 56%</p>
              </div>
              <div class="regime-confidence">
                <span class="regime-conf-bar" style="--w: 14%"></span>
                <span class="regime-conf-val">14%</span>
              </div>
            </div>
          </div>

          <!-- Strategy adaptation arrow -->
          <div class="mt-7 pt-6 border-t border-gold/20">
            <p class="text-[10px] uppercase tracking-[0.32em] text-ink/50 mb-3">→ Применяемая корректировка</p>
            <div class="grid grid-cols-3 gap-3">
              <div class="param-card">
                <p class="param-label">Множитель лота</p>
                <p class="param-val">1.30 → <span class="text-laurel">1.35</span></p>
              </div>
              <div class="param-card">
                <p class="param-label">Расстояние сетки</p>
                <p class="param-val">30 → <span class="text-laurel">28 п.</span></p>
              </div>
              <div class="param-card">
                <p class="param-label">Take Profit</p>
                <p class="param-val">2.0% → <span class="text-laurel">1.8%</span></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: explanation cards -->
      <div class="space-y-4">
        <div class="adaptive-feature reveal">
          <div class="adaptive-feature-num">α</div>
          <div>
            <h3 class="display text-xl font-semibold">Walk-forward 70/30</h3>
            <p class="mt-1.5 text-sm text-ink/70">
              Параметры подбираются на 70% истории, валидируются на оставшихся 30%.
              Если out-of-sample слабее — изменения отбрасываются.
            </p>
          </div>
        </div>
        <div class="adaptive-feature reveal">
          <div class="adaptive-feature-num">β</div>
          <div>
            <h3 class="display text-xl font-semibold">Champion-challenger</h3>
            <p class="mt-1.5 text-sm text-ink/70">
              Новый набор побеждает только если он на ≥5% лучше по Sharpe ratio
              <strong>и</strong> просадка не выросла больше чем на 20%.
            </p>
          </div>
        </div>
        <div class="adaptive-feature reveal">
          <div class="adaptive-feature-num">γ</div>
          <div>
            <h3 class="display text-xl font-semibold">Optuna 100 trials</h3>
            <p class="mt-1.5 text-sm text-ink/70">
              Bayesian-оптимизация перебирает grid spacing, lot multiplier,
              max levels — за ~3 минуты на ноутбуке.
            </p>
          </div>
        </div>
        <div class="adaptive-feature reveal">
          <div class="adaptive-feature-num">δ</div>
          <div>
            <h3 class="display text-xl font-semibold">Откат одной кнопкой</h3>
            <p class="mt-1.5 text-sm text-ink/70">
              История калибровок сохраняется через `parent_id` — не понравились
              новые параметры, восстанавливаем предыдущие за секунду.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .regime-stage { perspective: 1000px; }

  .regime-display {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .regime-card {
    display: grid;
    grid-template-columns: 36px 1fr 120px;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-radius: 12px;
    border: 1px solid rgba(201, 169, 110, 0.22);
    background: rgba(255, 255, 255, 0.55);
    transition: all 0.3s;
  }
  .regime-card:hover {
    transform: translateX(4px);
    border-color: rgba(201, 169, 110, 0.5);
  }

  .regime-trend {
    border-color: rgba(91, 123, 74, 0.5);
    background: rgba(126, 139, 90, 0.12);
    box-shadow: 0 0 0 2px rgba(91, 123, 74, 0.15);
  }

  .regime-icon { font-size: 1.5rem; line-height: 1; }
  .regime-label {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: #1B2940;
  }
  .regime-meta {
    font-size: 0.7rem;
    color: rgba(42, 37, 32, 0.55);
    font-family: "JetBrains Mono", monospace;
    margin-top: 0.1rem;
  }
  .regime-confidence {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .regime-conf-bar {
    flex: 1;
    height: 4px;
    border-radius: 2px;
    background: linear-gradient(90deg, #F4D783, #D4AF37, #9B7B2D);
    width: var(--w, 0%);
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.55);
    animation: bar-fill 1.4s cubic-bezier(0.2, 0.65, 0.3, 1) forwards;
    transform-origin: left;
    transform: scaleX(0);
  }
  .regime-trend .regime-conf-bar {
    background: linear-gradient(90deg, #5B7B4A, #7E8B5A, #9CB077);
  }
  .regime-conf-val {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    font-weight: 700;
    color: #1B2940;
    width: 32px;
    text-align: right;
  }
  @keyframes bar-fill {
    to { transform: scaleX(1); }
  }

  .param-card {
    border: 1px solid rgba(201, 169, 110, 0.22);
    border-radius: 10px;
    padding: 0.55rem 0.7rem;
    background: rgba(255, 255, 255, 0.4);
    text-align: center;
  }
  .param-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(42, 37, 32, 0.55);
  }
  .param-val {
    margin-top: 0.3rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    font-weight: 700;
    color: #1B2940;
  }
  .text-laurel { color: #5B7B4A; }

  .adaptive-feature {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1rem;
    align-items: start;
    padding: 1.2rem 1.4rem;
    border-radius: 16px;
    background: rgba(250, 246, 236, 0.5);
    border: 1px solid rgba(201, 169, 110, 0.22);
    transition: all 0.25s;
  }
  .adaptive-feature:hover {
    background: rgba(250, 246, 236, 0.85);
    border-color: rgba(201, 169, 110, 0.45);
    transform: translateX(-4px);
  }
  .adaptive-feature-num {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #F4D783, #D4AF37, #9B7B2D);
    color: #15233A;
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 1.4rem;
    font-weight: 700;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      0 6px 14px -4px rgba(168, 136, 79, 0.4);
  }
</style>
