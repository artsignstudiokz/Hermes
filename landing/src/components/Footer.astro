---
const PRODUCT_LINKS = [
  { href: "#features", label: "Возможности" },
  { href: "#how", label: "Как работает" },
  { href: "#screens", label: "Интерфейс" },
  { href: "#download", label: "Скачать" },
];

const COMPANY_LINKS = [
  { href: "https://baicore.kz", label: "Сайт компании", external: true },
  { href: "mailto:info@baicore.kz", label: "info@baicore.kz" },
  { href: "mailto:support@baicore.kz", label: "support@baicore.kz" },
];

const LEGAL_LINKS = [
  { href: "#faq", label: "FAQ" },
  { href: "/legal/license", label: "Лицензия" },
  { href: "/legal/privacy", label: "Конфиденциальность" },
  { href: "/legal/terms", label: "Условия использования" },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-gold/25 bg-alabaster/60 py-12">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-3">
          <img src="/hermes-emblem.svg" width="36" height="36" alt="" />
          <div class="leading-none">
            <div class="font-serif text-xl font-semibold gold-text">Hermes</div>
            <div class="text-[10px] uppercase tracking-[0.28em] text-ink/55 mt-0.5">
              BAI Core · Trading
            </div>
          </div>
        </div>
        <p class="mt-4 max-w-sm font-serif text-sm text-ink/65">
          «Нет дома богаче того, в котором живёт Гермес — посланник прибыли.»
        </p>
        <p class="mt-4 text-[11px] uppercase tracking-[0.22em] text-ink/45">
          © {year} BAI Core · baicore.kz
        </p>
      </div>

      <div>
        <h4 class="text-xs uppercase tracking-[0.28em] text-ink/55">Продукт</h4>
        <ul class="mt-3 space-y-2 text-sm">
          {PRODUCT_LINKS.map((l) => (
            <li><a class="link-sub" href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs uppercase tracking-[0.28em] text-ink/55">BAI Core</h4>
        <ul class="mt-3 space-y-2 text-sm">
          {COMPANY_LINKS.map((l) => (
            <li>
              <a
                class="link-sub"
                href={l.href}
                {...(l.external ? { target: "_blank", rel: "noreferrer" } : {})}
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs uppercase tracking-[0.28em] text-ink/55">Документы</h4>
        <ul class="mt-3 space-y-2 text-sm">
          {LEGAL_LINKS.map((l) => (
            <li><a class="link-sub" href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="meander-stripe mt-12 h-5 opacity-40"></div>

    <p class="mt-6 text-center text-[11px] uppercase tracking-[0.3em] text-ink/45">
      Сделано в Казахстане · Hermes возносится над рынками
    </p>
  </div>
</footer>
