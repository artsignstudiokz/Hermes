---
import ParallaxDashboard from "./ParallaxDashboard.astro";
---

<section class="relative overflow-hidden pt-32 pb-32 md:pt-40 md:pb-40">
  <!-- Multi-layer animated mesh background -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <div class="hero-blob hero-blob-1"></div>
    <div class="hero-blob hero-blob-2"></div>
    <div class="hero-blob hero-blob-3"></div>
    <div class="meander-stripe absolute inset-x-0 top-20 h-5 opacity-35"></div>
    <div class="meander-stripe absolute inset-x-0 bottom-12 h-5 opacity-35 rotate-180"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6">
    <!-- Headline block (centered above the dashboard) -->
    <div class="text-center">
      <!-- Live status pill with double-ripple -->
      <div class="reveal inline-flex items-center gap-2.5 rounded-full border border-gold/40 bg-alabaster/85 px-4 py-1.5 text-[11px] uppercase tracking-[0.28em] text-gold-deep backdrop-blur-md shadow-sm">
        <span class="ping-double relative inline-flex h-1.5 w-1.5">
          <span class="absolute inset-0 rounded-full bg-laurel opacity-70 animate-ping"></span>
          <span class="absolute inset-0 rounded-full bg-laurel/50 ping-ripple-2"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-laurel"></span>
        </span>
        Версия 1.0 · Скоро релиз
      </div>

      <h1 class="display mt-7 text-5xl md:text-7xl lg:text-[80px] font-semibold leading-[0.95] tracking-tight max-w-4xl mx-auto">
        <span class="word-reveal" style="transition-delay: 0.05s">Бог</span>
        <span class="word-reveal" style="transition-delay: 0.15s">торговли.</span>
        <br />
        <span class="word-reveal headline-accent gold-text-anim italic" style="transition-delay: 0.35s">Ваш</span>
        <span class="word-reveal headline-accent gold-text-anim italic" style="transition-delay: 0.45s">бот.</span>
        <span class="headline-underline" aria-hidden="true"></span>
      </h1>

      <p class="reveal mt-7 mx-auto max-w-2xl font-serif text-lg md:text-xl leading-relaxed text-ink/70" style="transition-delay: 0.55s">
        Профессиональный трейдинг-бот, объединивший мудрость античного покровителя коммерции
        и точность современных алгоритмов. Один клик — и Hermes торгует за вас 24/7.
      </p>

      <!-- CTA cluster -->
      <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-3" style="transition-delay: 0.75s">
        <button
          id="primary-download"
          type="button"
          class="magnetic gold-button-morph group inline-flex items-center gap-2.5 rounded-2xl px-7 py-4 text-sm font-bold uppercase tracking-[0.16em] shadow-gold"
        >
          <span id="primary-icon" aria-hidden="true">⬇</span>
          <span>Скачать <span id="primary-os-label">для вашей системы</span></span>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
        </button>
        <button
          id="other-os-toggle"
          type="button"
          class="inline-flex items-center gap-2 rounded-2xl border border-gold/40 bg-alabaster/70 backdrop-blur-md px-5 py-4 text-sm font-medium text-ink/80 hover:bg-parchment/80 hover:border-gold/60 transition"
        >
          Другие системы
          <svg viewBox="0 0 20 20" width="14" height="14" fill="currentColor" aria-hidden="true">
            <path d="M5.23 7.21a.75.75 0 011.06.02L10 11.08l3.71-3.85a.75.75 0 111.08 1.04l-4.25 4.4a.75.75 0 01-1.08 0l-4.25-4.4a.75.75 0 01.02-1.06z"/>
          </svg>
        </button>
      </div>

      <div id="other-os-panel" class="hidden mt-3 inline-flex flex-wrap gap-2 justify-center">
        <a href="#" data-os="windows" class="os-pill"><span class="os-icon">⊞</span> Windows · .exe</a>
        <a href="#" data-os="macos" class="os-pill"><span class="os-icon"></span> macOS · .pkg</a>
        <a href="#" data-os="linux" class="os-pill"><span class="os-icon">🐧</span> Linux · .AppImage <span class="os-soon">скоро</span></a>
      </div>

      <p id="primary-meta" class="reveal mt-4 text-xs text-ink/55" style="transition-delay: 0.85s">
        ~80 МБ · Свободное распространение для частного использования
      </p>

      <!-- Trust line -->
      <div class="reveal mt-10 flex flex-wrap items-center justify-center gap-x-10 gap-y-3 text-xs uppercase tracking-[0.24em] text-ink/50" style="transition-delay: 0.95s">
        <span class="trust-item">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#A8884F" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
          MetaTrader 5
        </span>
        <span class="trust-item">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#A8884F" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
          Binance · Bybit · OKX
        </span>
        <span class="trust-item">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#A8884F" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4"/></svg>
          Argon2id шифрование
        </span>
        <span class="trust-item">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#A8884F" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
          Мобильный доступ
        </span>
      </div>
    </div>

    <!-- Parallax 3D Dashboard centerpiece -->
    <div class="reveal-late mt-20 lg:mt-24">
      <ParallaxDashboard />
    </div>
  </div>
</section>
